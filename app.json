{
  "expo": {
    "name": "Pinchanted",
    "slug": "pinchanted",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1554"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ca.pinchanted.claude",
      "infoPlist": {
        "NSCameraUsageDescription": "Pinchanted uses your camera to photograph pins for AI identification.",
        "NSPhotoLibraryUsageDescription": "Pinchanted accesses your photo library so you can upload pin images.",
        "NSPhotoLibraryAddUsageDescription": "Pinchanted saves pin images to your photo library.",
        "softwareKeyboardLayoutMode": "pan",
        "navigationBarColor": "#08103d",
        "edgeToEdgeEnabled": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ca.pinchanted.claude",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b1554"
      },
"permissions": [
  "android.permission.CAMERA",
  "android.permission.READ_EXTERNAL_STORAGE",
  "android.permission.WRITE_EXTERNAL_STORAGE",
  "android.permission.RECEIVE_BOOT_COMPLETED",
  "android.permission.VIBRATE"
]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0f1d6e",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pinchanted accesses your photos to let you upload pin images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "pinchanted",
    "extra": {
      "eas": {
        "projectId": "a94cd50a-7cb7-41b2-9504-3e6ab7c62a13"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a94cd50a-7cb7-41b2-9504-3e6ab7c62a13"
    }
  }
}
