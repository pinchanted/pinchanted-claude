{
  "expo": {
    "name": "Pinchanted",
    "slug": "pinchanted",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1554"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pinchanted.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Pinchanted uses your camera to photograph pins for AI identification.",
        "NSPhotoLibraryUsageDescription": "Pinchanted accesses your photo library so you can upload pin images.",
        "NSPhotoLibraryAddUsageDescription": "Pinchanted saves pin images to your photo library."
      }
    },
    "android": {
      "package": "com.pinchanted.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b1554"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0f1d6e",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pinchanted accesses your photos to let you upload pin images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "pinchanted",
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}